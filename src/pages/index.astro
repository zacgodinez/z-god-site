---
import Layout from '~/layouts/PageLayout.astro';
import Z3Layout from '~/components/common/Z3Layout.astro';
import HomePostsItem from '~/components/blog/HomePostsItem.astro';
import { APP_BLOG } from 'astrowind:config';
import { findLatestPosts } from '~/utils/blog';

const posts = APP_BLOG.isEnabled ? await findLatestPosts({ count: 10 }) : [];

const metadata = {
  title: 'ZG.codes — Personal blog',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Z3Layout linkLogo={false}>
    <div class="px-6 pt-4">
      <p class="text-muted-foreground">
        Hi
        <span class="text-2xl"> 👋 </span>
        I'm <span class="font-black">ZG</span>
        <br /><br />I'm a dev who enjoys the creative coding and building UI's. I am a crypto enthusiast and am building
        an open source crypto wallet, check it out at <a href="https://z3us.com/">Z3US.com</a>.<br />
        I post on X you can follow me on <a href="https://x.com/zac_godinez">X</a>.
      </p>
    </div>
    <div class="px-6 pb-2 pt-8">
      <h1 class="mb-2 font-sans text-lg font-black uppercase">Posts</h1>
      <ul class="zg-list flex flex-col gap-6">
        {posts.map((post, _postIndex) => <HomePostsItem post={post} isFirst={_postIndex === 0} />)}
      </ul>
    </div>
  </Z3Layout>
</Layout>
